{
  "name": "spk-cup-server",
  "version": "1.0.0",
  "private": true,
  "description": "Torny Tournament App - Express.js Backend",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && npm run copy-sql",
    "copy-sql": "node -e \"const fs=require('fs'),path=require('path');const src=path.join('src','db'),dst=path.join('dist','db');if(fs.existsSync(dst))fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('SQL migrations copied to dist/db');\"",
    "test": "vitest --run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@types/web-push": "^3.6.4",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.3"
  }
}
