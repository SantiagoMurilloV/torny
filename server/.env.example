# ────────────────────────────────────────────────────────────
# LOCAL DEV (keeps DB_* vars, PORT, etc.)
# ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Local Postgres. Ignored if DATABASE_URL is set (e.g. in prod).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=spkcup
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# JWT — MUST be at least 16 chars in production.
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ────────────────────────────────────────────────────────────
# PRODUCTION (Railway) — set these in Railway's dashboard
# ────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL once you add the Postgres plugin.
# If DATABASE_URL is present, the DB_* vars above are ignored.
# DATABASE_URL=postgresql://user:pass@host:port/db
#
# Comma-separated list of Vercel origins allowed to call the API.
# Include BOTH the main domain and every preview URL you care about.
# CORS_ORIGINS=https://torny.app,https://www.torny.app
#
# Public origin of the backend itself — used to build absolute URLs for
# uploaded images so the Vercel frontend can load them from Railway.
# PUBLIC_URL=https://spike-production-6ba4.up.railway.app

# ────────────────────────────────────────────────────────────
# AI agents
# ────────────────────────────────────────────────────────────
# DeepSeek powers the tournament wizard assistant + the admin agent
# (function-calling loop).
# DEEPSEEK_API_KEY=sk-...
#
# Groq powers the AI schedule advisor (POST /tournaments/:id/schedule-advice
# and the agent's analyze_schedule tool). OpenAI-compatible API.
# Without GROQ_API_KEY the advisor still returns deterministic metrics,
# just no AI prose/recommendations.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile   # override if Groq deprecates it
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions  # escape hatch
